PROJECT_NAME= "Blackjack Vision"

ENVIRONMENT=local

# API key for securing endpoints
API_KEY=changethis

# Database settings
MYSQL_HOST=blackjack-vision.c4b2gq104xec.ap-southeast-1.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=my-secret-pw
MYSQL_DB=blackjack_vision

# Video processing settings
LOCAL_UPLOAD_DIR=data/uploads
MAX_UPLOAD_MB=3072

###################### Vision  Settings ######################
# === Video & Replay Detection ===
VIDEO_PATH=$HOME/Downloads/blackjack-sample-videos/trimmed-digital-mode-blackjack.mov
REPLAY_THRESHOLD=0.8
# === Card Detection ===
CARD_THRESHOLD=0.8

# === Output ===
OUTPUT_DIR=game-sessions
OUTPUT_PREFIX=session
IMAGE_EXT=jpg

# # === 4K Videos - ROIs (x1,y1,x2,y2) - Top-left and bottom-right coordinates ===
# DEALER_TEMPLATE_DIR=template-images/4k/dealer
# PLAYER_TEMPLATE_DIR=template-images/4k/players
# REPLAY_TEMPLATE=template-images/4k/replay.jpg

REPLAY_ROI=1000,1020,1150,1150
DEALER_ROI=1070,560,1300,593
PLAYER_1_ROI=1045,1183,1077,1467
PLAYER_2_ROI=1225,1260,1255,1534
PLAYER_3_ROI=1440,1300,1475,1580
PLAYER_4_ROI=1675,1240,1705,1594
PLAYER_5_ROI=1910,1300,1938,1578 
PLAYER_6_ROI=2126,1270,2156,1536
PLAYER_7_ROI=2305,1200,2335,1464

