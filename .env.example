PROJECT_NAME= "Blackjack Vision"

# Set to "production" in production environments to enforce stricter validation and security checks
# "local", "staging", "production"
ENVIRONMENT="local"

# API key for securing endpoints
API_KEY=changethis

# Database settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=username
MYSQL_PASSWORD=changethis
MYSQL_DB=blackjack_vision

# Video processing settings
LOCAL_UPLOAD_DIR=data/uploads
MAX_UPLOAD_MB=512

###################### Vision  Settings ######################
# === Video & Replay Detection ===
REPLAY_THRESHOLD=0.8
# === Card Detection ===
CARD_THRESHOLD=0.8
# === Cut Card Detection ===
# Minimum fraction of the cut-card ROI that the largest white blob must cover
# for the white cut card to be considered visible. Lower values are more
# sensitive; raise if the dealer's shirt/sleeve causes false positives.
CUT_CARD_THRESHOLD=0.15
